            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/sales", "host": ["{{base_url}}"], "path": ["api", "sales"] }
          }
        },
        {
          "name": "Create Sale",
          "request": {
            "method": "POST",
