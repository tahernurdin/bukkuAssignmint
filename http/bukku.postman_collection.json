              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/sales/1", "host": ["{{base_url}}"], "path": ["api", "sales", "1"] }
          }
        }
      ]
    },
    {
      "name": "Dashboards",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/admin-dashboard", "host": ["{{base_url}}"], "path": ["api", "admin-dashboard"] }
          }
        },
        {
          "name": "User Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/user-dashboard", "host": ["{{base_url}}"], "path": ["api", "user-dashboard"] }
          }
